{
  "name": "github-issue-glance",
  "displayName": "Github Issue Glance",
  "version": "1.3.0",
  "author": "qwadrox",
  "description": "Helps you bookmark and manage GitHub issues with ease",
  "type": "module",
  "license": "Unlicense",
  "keywords": [
    "github chrome extension",
    "github issues",
    "bookmark issues",
    "github issue organizer",
    "github issue glance"
  ],
  "engines": {
    "node": ">=18.17.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "format": "prettier --write '**/*.{ts,json,css,scss,md}'",
    "format-check": "prettier --check '**/*.{ts,json,css,scss,md}'",
    "zip": "pnpm build",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.4.0",
    "@types/chrome": "^0.1.38",
    "@types/jest": "^29.5.14",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "prettier": "^3.8.1",
    "ts-jest": "^29.4.6",
    "typescript": "^5.2.2",
    "vite": "^8.0.3",
    "vite-plugin-zip-pack": "^1.2.4"
  },
  "dependencies": {
    "ag-grid-community": "^33.0.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "es5-ext",
      "esbuild",
      "fsevents"
    ]
  }
}
